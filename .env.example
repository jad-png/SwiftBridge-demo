# SwiftBridge - Environment Template
# Copy this file to .env.local and update values for local development
# DO NOT commit .env.local to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection settings (used by Orchestrator Service)

# Database host (Docker service name or localhost for local development)
DB_HOST=postgres-db
DB_PORT=5432
DB_NAME=swiftbridge
DB_USER=swiftbridge_user
DB_PASSWORD=SwiftBridge@123!Secure

# Connection pool settings
DB_POOL_SIZE=10
DB_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Orchestrator Service
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_NAME=orchestrator-service
ORCHESTRATOR_PROFILE=docker
ORCHESTRATOR_JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC

# Core Converter Service
CONVERTER_PORT=8081
CONVERTER_NAME=core-converter-service
CONVERTER_PROFILE=docker
CONVERTER_JAVA_OPTS=-Xmx256m -Xms128m -XX:+UseG1GC -XX:MaxGCPauseMillis=100

# Service-to-service communication (Docker network)
CORE_CONVERTER_URL=http://core-converter-service:8081
ORCHESTRATOR_URL=http://orchestrator-service:8080

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT Configuration
JWT_ENABLED=false
JWT_SECRET=your-secret-key-min-32-chars-change-in-production
JWT_EXPIRATION=86400000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# API Security
API_KEY_ENABLED=false
API_KEY=your-api-key-change-in-production
INTERNAL_API_KEY=your-internal-api-key-change-in-production

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Root logging level
LOG_LEVEL=INFO

# Component-specific logging levels
LOG_LEVEL_ORCHESTRATOR=DEBUG
LOG_LEVEL_CONVERTER=DEBUG
LOG_LEVEL_DATABASE=DEBUG
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_SQL=DEBUG

# Logging format
LOG_FORMAT=JSON
LOG_FILE_PATH=/var/log/swiftbridge
LOG_FILE_MAX_SIZE=100MB
LOG_FILE_MAX_DAYS=30

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Thread pool settings (Orchestrator)
ORCHESTRATOR_MAX_THREADS=200
ORCHESTRATOR_MIN_SPARE_THREADS=10
ORCHESTRATOR_QUEUE_CAPACITY=100

# Thread pool settings (Converter)
CONVERTER_MAX_THREADS=250
CONVERTER_MIN_SPARE_THREADS=20
CONVERTER_QUEUE_CAPACITY=100

# Connection timeouts (milliseconds)
CONNECT_TIMEOUT=5000
READ_TIMEOUT=10000
WRITE_TIMEOUT=10000

# Converter-specific settings
CONVERTER_BATCH_ENABLED=true
CONVERTER_BATCH_SIZE=50
CONVERTER_VALIDATION_MODE=strict

# ============================================================================
# ACTUATOR & MONITORING
# ============================================================================

# Health check configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=15s
HEALTH_CHECK_TIMEOUT=10s

# Metrics and monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9091

# Actuator endpoints
ACTUATOR_HEALTH_DETAILS=when-authorized
ACTUATOR_ENDPOINTS_INCLUDE=health,info,metrics,prometheus

# ============================================================================
# DOCKER CONFIGURATION
# ============================================================================

# Docker registry (for production image pulls)
DOCKER_REGISTRY=your-registry.azurecr.io
DOCKER_IMAGE_TAG=1.0.0
DOCKER_BUILDKIT=1

# PostgreSQL Docker image
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_VOLUME=postgres_data

# Network configuration
DOCKER_NETWORK=swiftbridge_network
DOCKER_NETWORK_SUBNET=172.20.0.0/16

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================

# Maven settings
MAVEN_VERSION=3.9
JAVA_VERSION=17
MAVEN_OFFLINE_MODE=false

# Hot reload (for development)
SPRING_DEVTOOLS_ENABLED=true
SPRING_DEVTOOLS_LIVERELOAD_ENABLED=true

# Database initialization
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_SQL_FORMAT=true

# ============================================================================
# APPLICATION FEATURES
# ============================================================================

# Feature flags
FEATURE_JWT_AUTH=false
FEATURE_RATE_LIMITING=false
FEATURE_CACHING=true
FEATURE_AUDIT_LOGGING=true
FEATURE_METRICS=true

# Rate limiting (if enabled)
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_REQUESTS_PER_HOUR=100000

# Caching configuration
CACHE_TYPE=in-memory
CACHE_TTL=3600

# ============================================================================
# EXTERNAL SERVICES (Future integrations)
# ============================================================================

# SWIFT Gateway (when applicable)
SWIFT_GATEWAY_URL=https://swift.example.com
SWIFT_GATEWAY_TIMEOUT=30000
SWIFT_GATEWAY_ENABLED=false

# Audit Logging Service
AUDIT_SERVICE_URL=http://audit-service:8082
AUDIT_SERVICE_ENABLED=false

# Analytics Service
ANALYTICS_SERVICE_URL=http://analytics-service:8083
ANALYTICS_SERVICE_ENABLED=false

# ============================================================================
# BACKUP & DISASTER RECOVERY
# ============================================================================

# Database backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/backups

# ============================================================================
# OBSERVABILITY
# ============================================================================

# Distributed tracing
TRACING_ENABLED=false
TRACING_JAEGER_URL=http://jaeger:6831

# Custom application metrics
APP_METRICS_ENABLED=true
APP_METRICS_CONVERTER_THROUGHPUT=true
APP_METRICS_CONVERSION_TIME=true
APP_METRICS_DB_QUERY_TIME=true

# ============================================================================
# NOTES
# ============================================================================
# 1. This file is for LOCAL DEVELOPMENT ONLY
# 2. Production credentials should be stored in secure vaults:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Kubernetes Secrets
# 3. Never commit credentials to Git
# 4. Use different passwords for different environments
# 5. Rotate credentials every 90 days in production
# 6. Enable multi-factor authentication in production
#
# Last Updated: February 2026
# Maintained by: SwiftBridge Architecture Team
